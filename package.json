{
  "name": "tga-parent-app",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nest build && echo Build completed successfully.",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node --max-old-space-size=4096 dist/main.js",
    "start:dev": "cross-env NODE_ENV=development NODE_OPTIONS=--max-old-space-size=4096 nest start --watch --no-type-check",
    "start:debug": "cross-env NODE_ENV=development NODE_OPTIONS=--max-old-space-size=4096 nest start --debug --watch",
    "start:staging": "node --max-old-space-size=4096 dist/main",
    "start:prod": "cross-env NODE_ENV=production node --max-old-space-size=4096 dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ts-node src/database/migrate.ts",
    "migrate:rollback": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ts-node src/database/migrate.ts rollback",
    "db:seed": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ts-node src/database/seed.ts",
    "seed": "cross-env NODE_OPTIONS=--max-old-space-size=4096 ts-node src/database/seed.ts"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.0.1",
    "@google-cloud/storage": "^7.17.2",
    "@nestjs-modules/mailer": "^2.0.0",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.12",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/serve-static": "^5.0.1",
    "@nestjs/swagger": "^11.0.3",
    "@nestjs/throttler": "6.4.0",
    "@nestjs/websockets": "^11.1.12",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.3",
    "@types/socket.io": "^3.0.1",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "cache-manager": "^6.4.0",
    "cache-manager-redis-store": "3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "ejs": "3.1.10",
    "express": "^5.1.0",
    "firebase-admin": "^13.5.0",
    "googleapis": "^162.0.0",
    "handlebars": "4.7.8",
    "helmet": "^8.0.0",
    "liquidjs": "10.8.4",
    "mjml": "4.15.3",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.1",
    "nodemailer": "6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-microsoft": "^2.1.0",
    "path-browserify": "^1.0.1",
    "pdfkit": "^0.17.2",
    "preview-email": "3.0.20",
    "pug": "3.0.3",
    "puppeteer": "^24.32.0",
    "reflect-metadata": "0.1.13",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/mjml": "^4.7.4",
    "@types/mongodb": "^4.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.13.10",
    "@types/pug": "^2.0.10",
    "@types/serve-static": "^2.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "resolutions": {
    "html-minifier": "npm:html-minifier-terser",
    "cookie": "^0.7.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
